    <style>
       #filter {
    display: flex;
    flex-wrap: nowrap;   
    overflow-x: auto;   
    gap: 2rem;           
    padding: 1rem 0;     
}

.filter-container {
    text-align: center;
    cursor: pointer;
    opacity: 0.7;
    flex: 0 0 auto;      /* prevents shrinking, keeps them inline */
}

.filter-container:hover {
    opacity: 1;
}

.filter-container p {
    font-size: 0.8rem;
}

a.filter-link {
    text-decoration: none;
    color: inherit;
}
.tax-info {
    display: none; /* Hidden by default, shown when toggle is on */
}

    </style>

<div id="filter">

